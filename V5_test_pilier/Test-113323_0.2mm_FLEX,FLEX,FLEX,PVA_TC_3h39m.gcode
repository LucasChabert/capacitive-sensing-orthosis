; toolchange_gcode = ; Change Tool[previous_extruder] -> Tool[next_extruder] (layer [layer_num])\n\n{if current_extruder == next_extruder}; check if tool is already active at startup\nT[current_extruder] ; tool already active, don't change tools\n{else}  ; run tool change as expected\nG1 E-2 F2000 ; retract filament\nT-1 ; drop off current tool\nM109 S[temperature] T[next_extruder]\nT[next_extruder]      ; pick up next tool\n	{if layer_z <= disable_fan_first_layers[next_extruder]}; check if fan should be on for first layers\n	     M106 S0 ; set part cooling fan based on filament profile\n	          {else}; if layer height is above the minimum, enable fan\n	               M106 S255 ; set part cooling fan based on filament profile\n	{endif}\n{endif}
; toolchange_ordering = optimized
; top_fill_pattern = monotonic
