; start_filament_gcode = "; Filament gcode\n";"; Filament gcode\n";"; Filament gcode\n";"; Filament gcode\n"
; start_gcode = M104 ; prevent pusaslicer from adding temperature commands\n; run custom start G-code\nT-1  ; clear tool selection\nM144 S1 ; set bed as active\nM140 S[bed_temperature] R0 ; set bed temp\nG29 S1 ; activate mesh bed compensation and load saved heightmap\n\n; turn off unused heaters\n{if ! is_extruder_used[0]}M104 T0 S0{endif}\n{if ! is_extruder_used[1]}M104 T1 S0{endif}\n{if num_extruders > 2 and ! is_extruder_used[2]}M104 T2 S0{endif}\n{if num_extruders > 3 and ! is_extruder_used[3]}M104 T3 S0{endif}\n\n; homming\nG28 ; homing\n; try picking tools used in print\nG1 F{travel_speed * 60}\n;{if (is_extruder_used[0]) and (initial_tool != 0)}T0{endif}\n;{if (is_extruder_used[1]) and (initial_tool != 1)}T1{endif}\n;{if (is_extruder_used[2]) and (initial_tool != 2)}T2{endif}\n;{if (is_extruder_used[3]) and (initial_tool != 3)}T3{endif}\nG0 Z5 ; add Z clearance\nM190 S[bed_temperature] ; wait for bed temp\n\n; set extruder temp\n{if first_layer_temperature[0] > 0 and (is_extruder_used[0])}M104 T0 S{first_layer_temperature[0]}{endif}\n{if first_layer_temperature[1] > 0 and (is_extruder_used[1])}M104 T1 S{first_layer_temperature[1]}{endif}\n{if first_layer_temperature[2] > 0 and (is_extruder_used[2])}M104 T2 S{first_layer_temperature[2]}{endif}\n{if first_layer_temperature[3] > 0 and (is_extruder_used[3])}M104 T3 S{first_layer_temperature[3]}{endif}\n{if (is_extruder_used[0]) and initial_tool != 0}\n;\n; purge first tool\n;\nG1 F{travel_speed * 60}\nT-1 ; park the tool\nM109 T0 S{first_layer_temperature[0]}\nT0 ; pick the tool\nG92 E0 ; reset extruder position\n\nG0 X320 Y175 Z10 F{(travel_speed * 60)} ; move close to the sheet's edge\nG0 E30 X310 Z0.2 F{if is_nil(filament_multitool_ramming[0])}500{else}170{endif} ; purge while moving towards the sheet\nG0 X285 E39 F800 ; continue purging and wipe the nozzle\nG0 X282 Z0.05 F8000 ; wipe, move close to the bed\nG0 X279 Z0.2 F8000 ; wipe, move quickly away from the bed\nG1 E{-retract_length_toolchange[0]} F2400 ; retract\n{e_retracted[0] = retract_length_toolchange[0]}\nG92 E0 ; reset extruder position\n\nM104 S{(is_nil(idle_temperature[0]) ? (first_layer_temperature[0] + standby_temperature_delta) : (idle_temperature[0]))} T0\n{endif}\n{if (is_extruder_used[1]) and initial_tool != 1}\n;\n; purge second tool\n;\nG1 F{travel_speed * 60}\nT-1 ; park the tool\nM109 T1 S{first_layer_temperature[1]}\nT1 ; pick the tool\nG92 E0 ; reset extruder position\n\nG0 X320 Y155 Z10 F{(travel_speed * 60)} ; move close to the sheet's edge\nG0 E30 X310 Z0.2 F{if is_nil(filament_multitool_ramming[1])}500{else}170{endif} ; purge while moving towards the sheet\nG0 X285 E39 F800 ; continue purging and wipe the nozzle\nG0 X282 Z0.05 F8000 ; wipe, move close to the bed\nG0 X279 Z0.2 F8000 ; wipe, move quickly away from the bed\nG1 E{-retract_length_toolchange[1]} F2400 ; retract\n{e_retracted[1] = retract_length_toolchange[1]}\nG92 E0 ; reset extruder position\n\nM104 S{(is_nil(idle_temperature[1]) ? (first_layer_temperature[1] + standby_temperature_delta) : (idle_temperature[1]))} T1\n{endif}\n{if (is_extruder_used[2]) and initial_tool != 2}\n;\n; purge third tool\n;\nG1 F{travel_speed * 60}\nT-1 ; park the tool\nM109 T2 S{first_layer_temperature[2]}\nT2 ; pick the tool\nG92 E0 ; reset extruder position\n\nG0 X320 Y135 Z10 F{(travel_speed * 60)} ; move close to the sheet's edge\nG0 E30 X310 Z0.2 F{if is_nil(filament_multitool_ramming[2])}500{else}170{endif} ; purge while moving towards the sheet\nG0 X285 E39 F800 ; continue purging and wipe the nozzle\nG0 X282 Z0.05 F8000 ; wipe, move close to the bed\nG0 X279 Z0.2 F8000 ; wipe, move quickly away from the bed\nG1 E{-retract_length_toolchange[2]} F2400 ; retract\n{e_retracted[2] = retract_length_toolchange[2]}\nG92 E0 ; reset extruder position\n\nM104 S{(is_nil(idle_temperature[2]) ? (first_layer_temperature[2] + standby_temperature_delta) : (idle_temperature[2]))} T2\n{endif}\n{if (is_extruder_used[3]) and initial_tool != 3}\n;\n; purge fourth tool\n;\nG1 F{travel_speed * 60}\nT-1 ; park the tool\nM109 T3 S{first_layer_temperature[3]}\nT3 ; pick the tool\nG92 E0 ; reset extruder position\n\nG0 X320 Y115 Z10 F{(travel_speed * 60)} ; move close to the sheet's edge\nG0 E30 X310 Z0.2 F{if is_nil(filament_multitool_ramming[3])}500{else}170{endif} ; purge while moving towards the sheet\nG0 X285 E39 F800 ; continue purging and wipe the nozzle\nG0 X282 Z0.05 F8000 ; wipe, move close to the bed\nG0 X279 Z0.2 F8000 ; wipe, move quickly away from the bed\nG1 E{-retract_length_toolchange[3]} F2400 ; retract\n{e_retracted[3] = retract_length_toolchange[3]}\nG92 E0 ; reset extruder position\n\nM104 S{(is_nil(idle_temperature[3]) ? (first_layer_temperature[3] + standby_temperature_delta) : (idle_temperature[3]))} T3\n{endif}\n;\n; purge initial tool\n;\nG1 F{travel_speed * 60}\nT-1 ; park the tool\nM109 T{initial_tool} S{first_layer_temperature[initial_tool]}\nT{initial_tool} ; pick the tool\nG92 E0 ; reset extruder position\n\nG0 X{(initial_tool < 3 ? 320 : 317)} Y{(initial_tool == 0 ? 195 : (initial_tool == 1 ? 175 : (initial_tool == 2 ? 155 : (initial_tool == 3 ? 135 : 130))))} Z10 F{(travel_speed * 60)} ; move close to the sheet's edge\nG0 E30 X310 Z0.2 F{if is_nil(filament_multitool_ramming[initial_tool])}500{else}170{endif} ; purge while moving towards the sheet\nG0 X285 E39 F800 ; continue purging and wipe the nozzle\nG0 X282 Z0.05 F{8000} ; wipe, move close to the bed\nG0 X279 Z0.2 F{8000} ; wipe, move quickly away from the bed\nG1 E-{retract_length[initial_tool]} F2400 ; retract\n\n{e_retracted[initial_tool] = retract_length[initial_tool]}\n\nG92 E0 ; reset extruder position\n\n
; support_material = 1
; support_material_angle = 0
; support_material_auto = 1
; support_material_bottom_contact_distance = 0
; support_material_bottom_interface_layers = -1
; support_material_buildplate_only = 0
; support_material_closing_radius = 2
; support_material_contact_distance = 0.18
; support_material_enforce_layers = 0
; support_material_extruder = 0
; support_material_extrusion_width = 0.36
; support_material_interface_contact_loops = 0
; support_material_interface_extruder = 0
; support_material_interface_layers = 3
; support_material_interface_pattern = rectilinear
; support_material_interface_spacing = 0.2
; support_material_interface_speed = 50%
; support_material_pattern = rectilinear
; support_material_spacing = 2
; support_material_speed = 80
; support_material_style = snug
; support_material_synchronize_layers = 0
; support_material_threshold = 40
; support_material_with_sheath = 1
; support_material_xy_spacing = 80%
; support_tree_angle = 40
; support_tree_angle_slow = 25
; support_tree_branch_diameter = 2
; support_tree_branch_diameter_angle = 5
; support_tree_branch_diameter_double_wall = 3
; support_tree_branch_distance = 1
; support_tree_tip_diameter = 0.8
; support_tree_top_rate = 15%
; temperature = 220,220,240,240
; template_custom_gcode = 
; thick_bridges = 0
; thin_walls = 0
; thumbnails = 
; thumbnails_format = PNG
; toolchange_gcode = ; Change Tool[previous_extruder] -> Tool[next_extruder] (layer [layer_num])\n\n{if current_extruder == next_extruder}; check if tool is already active at startup\nT[current_extruder] ; tool already active, don't change tools\n{else}  ; run tool change as expected\nG1 E-2 F2000 ; retract filament\nT-1 ; drop off current tool\nM109 S[temperature] T[next_extruder]\nT[next_extruder]      ; pick up next tool\n	{if layer_z <= disable_fan_first_layers[next_extruder]}; check if fan should be on for first layers\n	     M106 S0 ; set part cooling fan based on filament profile\n	          {else}; if layer height is above the minimum, enable fan\n	               M106 S255 ; set part cooling fan based on filament profile\n	{endif}\n{endif}
; toolchange_ordering = optimized
; top_fill_pattern = monotonic
; top_infill_extrusion_width = 0.42
; top_one_perimeter_type = none
; top_solid_infill_acceleration = 0
; top_solid_infill_speed = 50%
; top_solid_layers = 5
; top_solid_min_thickness = 0
; travel_acceleration = 0
; travel_lift_before_obstacle = 0,0,0,0
; travel_max_lift = 0,0,0,0
; travel_ramping_lift = 0,0,0,0
; travel_short_distance_acceleration = 0
; travel_slope = 0,0,0,0
; travel_speed = 400
; travel_speed_z = 12
; use_firmware_retraction = 0
; use_relative_e_distances = 1
; use_volumetric_e = 0
; variable_layer_height = 1
; wall_distribution_count = 1
; wall_transition_angle = 10
; wall_transition_filter_deviation = 25%
; wall_transition_length = 100%
; wipe = 0,0,0,0
; wipe_into_infill = 0
; wipe_into_objects = 0
; wipe_tower = 1
; wipe_tower_acceleration = 0
; wipe_tower_bridging = 10
; wipe_tower_brim_width = 3
; wipe_tower_cone_angle = 15
; wipe_tower_extra_flow = 100%
; wipe_tower_extra_spacing = 100%
; wipe_tower_extruder = 1
; wipe_tower_no_sparse_layers = 0
; wipe_tower_width = 60
; wiping_volumes_matrix = 0,140,140,140,140,0,140,140,140,140,0,140,140,140,140,0
; wiping_volumes_use_custom_matrix = 0
; xy_size_compensation = 0
; z_offset = 0
; prusaslicer_config = end
